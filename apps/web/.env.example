# AI assistant endpoint (optional)
# Deploy a Cloud Function that proxies to the Anthropic API,
# then set this to the function URL
# NEXT_PUBLIC_AI_ENDPOINT=https://us-central1-keystone-21811.cloudfunctions.net/ai

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_BUILDER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_BUILDER_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_DEVELOPER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_DEVELOPER_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_ANNUAL=price_...

# Market Data APIs (all free — register at links below)
# Census Bureau: api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# HUD User: huduser.gov/hudapi/public/register
HUD_API_TOKEN=
# Bureau of Labor Statistics: data.bls.gov/registrationEngine/
BLS_API_KEY=
# FRED (Federal Reserve): fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
