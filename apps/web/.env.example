# Firebase Admin SDK — JSON service account key (single-line string)
# Generate at: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the entire JSON file contents as a single line
FIREBASE_SERVICE_ACCOUNT_KEY=

# Claude AI API Key — get from console.anthropic.com
CLAUDE_API_KEY=

# Firebase Realtime Database secret (server-side only)
# Firebase Console > Project Settings > Service Accounts > Database Secrets
FIREBASE_DATABASE_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_BUILDER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_BUILDER_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_DEVELOPER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_DEVELOPER_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_ANNUAL=price_...

# Market Data APIs (all free — register at links below)
# Census Bureau: api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# HUD User: huduser.gov/hudapi/public/register
HUD_API_TOKEN=
# Bureau of Labor Statistics: data.bls.gov/registrationEngine/
BLS_API_KEY=
# FRED (Federal Reserve): fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Sentry Error Monitoring (optional)
# Create project at sentry.io, then get DSN from Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
